# ════════════════════════════════════════════════
#   ASCENDER — Arquivo de Configuração (.env)
#   Renomeie este arquivo para .env e preencha
# ════════════════════════════════════════════════

# ─── BANCO DE DADOS (Railway MySQL) ─────────────
DATABASE_URL=mysql://root:SUASENHA@centerbeam.proxy.rlwy.net:25335/railway

# ─── GOOGLE LOGIN ────────────────────────────────
# Crie em: console.cloud.google.com → Credenciais → ID do cliente OAuth
# Tipo: Aplicativo da Web
# Origens autorizadas: https://seusite.com.br
# URIs de redirecionamento: https://seusite.com.br
GOOGLE_CLIENT_ID=cole_aqui_seu_client_id.apps.googleusercontent.com

# ─── CLOUDFLARE R2 (Imagens) ────────────────────
R2_ACCESS_KEY_ID=cole_aqui_o_access_key_id
R2_SECRET_ACCESS_KEY=cole_aqui_o_secret_access_key
R2_ENDPOINT=https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET=ascender-imagens
R2_PUBLIC_URL=https://pub-XXXX.r2.dev

# ─── SEGURANÇA ───────────────────────────────────
# Gere uma chave forte em: openssl rand -hex 32
# Ou invente uma frase com +32 caracteres aleatórios
SESSION_SECRET=troque_por_string_aleatoria_de_32_ou_mais_chars

# ─── DONO DO SITE ────────────────────────────────
# Deixe vazio agora. Preencha após o primeiro login.
OWNER_OPEN_ID=

# ─── SERVIDOR ────────────────────────────────────
PORT=3001
NODE_ENV=production
# Seu domínio final (sem barra no final)
SITE_URL=https://seusite.com.br
